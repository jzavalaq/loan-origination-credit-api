# Application
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=prod

# JWT Configuration (generate a secure secret for production)
# Example: openssl rand -base64 32
JWT_SECRET=change-me-in-production-min-256-bits-required
JWT_EXPIRATION=86400000

# Database
POSTGRES_DB=loandb
POSTGRES_USER=loanuser
POSTGRES_PASSWORD=changeme
DB_URL=jdbc:postgresql://localhost:5432/loandb
DB_USERNAME=loanuser
DB_PASSWORD=changeme

# HikariCP Connection Pool
HIKARI_MAX_POOL_SIZE=20
HIKARI_MIN_IDLE=5
HIKARI_CONNECTION_TIMEOUT=30000

# Security
ALLOWED_ORIGINS=http://localhost:3000

# H2 Console (set to true only in development)
H2_CONSOLE_ENABLED=false

# Rate Limiting
RATE_LIMIT_AUTH_REQUESTS=20
RATE_LIMIT_AUTH_PERIOD=60
